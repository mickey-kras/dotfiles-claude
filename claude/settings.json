{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(python3 *)",
      "Bash(pip *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(jq *)",
      "Bash(curl *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(chmod +x *)",
      "Bash(make *)",
      "Bash(docker *)",
      "Bash(brew *)",
      "Read",
      "Edit",
      "Write",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(rm -rf /)",
      "Bash(dd if=/dev/zero*)",
      "Bash(chmod 777 *)",
      "Bash(> /dev/sda*)"
    ]
  },
  "env": {
    "EDITOR": "code --wait"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles-claude/claude/hooks/scripts/security-audit.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "$HOME/dotfiles-claude/claude/hooks/scripts/startup-sync.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "$HOME/dotfiles-claude/claude/hooks/scripts/check-connectors.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles-claude/claude/hooks/scripts/auto-commit-config.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
