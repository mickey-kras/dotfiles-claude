# chezmoi:template:left-delimiter="# {{" right-delimiter="}}"
# Registers MCP servers in Claude Code CLI and Claude Desktop App.
# Idempotent: removes then re-adds each server.
# Re-runs only when template output changes (chezmoi run_onchange_).
#
# hash: # {{ include "dot_cursor/mcp.json.tmpl" | sha256sum }}

$ErrorActionPreference = "Continue"
$failed = 0

# ============================================================
# 1. Claude Code CLI - via `claude mcp add`
# ============================================================

if (Get-Command claude -ErrorAction SilentlyContinue) {
    Write-Host "Configuring Claude Code CLI MCPs..."
    $devDir = Join-Path $env:USERPROFILE "Dev"
    $bwMcp = Join-Path $env:USERPROFILE ".local\bin\bw-mcp"
    New-Item -ItemType Directory -Path $devDir -Force | Out-Null

    function Add-MCP {
        param([string]$Name, [string[]]$Args)
        claude mcp remove --scope user $Name 2>$null
        claude mcp add --scope user @Args 2>$null
        if ($LASTEXITCODE -eq 0) {
            Write-Host "  + $Name"
        } else {
            Write-Host "  ! $Name (failed)"
            $script:failed++
        }
    }

    # Core MCPs (always installed)
    Add-MCP -Name "playwright" -Args @("playwright", "--", "npx", "-y", "@playwright/mcp@0.0.68")
    Add-MCP -Name "context7" -Args @("--transport", "http", "context7", "https://mcp.context7.com/mcp")
    Add-MCP -Name "figma" -Args @("--transport", "http", "figma", "https://mcp.figma.com/mcp")
    Add-MCP -Name "filesystem" -Args @("filesystem", "--", "npx", "-y", "@modelcontextprotocol/server-filesystem@2026.1.14", $devDir)
    Add-MCP -Name "git" -Args @("git", "--", "npx", "-y", "@cyanheads/git-mcp-server@2.10.5")
    Add-MCP -Name "shell" -Args @("shell", "--", "npx", "-y", "super-shell-mcp@2.0.15")
    Add-MCP -Name "terraform" -Args @("terraform", "--", "npx", "-y", "terraform-mcp-server@0.13.0")
    Add-MCP -Name "kubernetes" -Args @("kubernetes", "--", "npx", "-y", "mcp-server-kubernetes@3.4.0")
    Add-MCP -Name "process" -Args @("process", "--", "npx", "-y", "@ai-capabilities-suite/mcp-process@1.5.10")
    Add-MCP -Name "thinking" -Args @("thinking", "--", "npx", "-y", "@modelcontextprotocol/server-sequential-thinking@2025.12.18")
    Add-MCP -Name "memory" -Args @("memory", "--", "npx", "-y", "@modelcontextprotocol/server-memory@2026.1.26")
    if (Get-Command uvx -ErrorAction SilentlyContinue) {
        Add-MCP -Name "http" -Args @("http", "--", "uvx", "mcp-server-fetch==2025.4.7")
    } else {
        Write-Host "  ! http (uvx not found)"
    }
    if (Get-Command bw -ErrorAction SilentlyContinue) {
        Add-MCP -Name "github" -Args @("github", "--", "node", $bwMcp, "mcp-github", "GITHUB_PERSONAL_ACCESS_TOKEN=password", "--", "npx", "-y", "@modelcontextprotocol/server-github@2025.4.8")
        Add-MCP -Name "tailscale" -Args @("tailscale", "--", "node", $bwMcp, "mcp-tailscale", "TAILSCALE_API_KEY=password,TAILSCALE_TAILNET=TAILSCALE_TAILNET", "--", "npx", "-y", "@hexsleeves/tailscale-mcp-server@0.3.2")
        if (Get-Command uvx -ErrorAction SilentlyContinue) {
            Add-MCP -Name "aws" -Args @("aws", "--", "node", $bwMcp, "mcp-aws", "AWS_ACCESS_KEY_ID=AWS_ACCESS_KEY_ID,AWS_SECRET_ACCESS_KEY=AWS_SECRET_ACCESS_KEY", "--", "uvx", "awslabs.aws-api-mcp-server==1.3.26")
        } else {
            Write-Host "  ! aws (uvx not found)"
        }
    } else {
        Write-Host "  ! github (Bitwarden CLI not found)"
        Write-Host "  ! aws (Bitwarden CLI not found)"
        Write-Host "  ! tailscale (Bitwarden CLI not found)"
    }
    if (Get-Command docker -ErrorAction SilentlyContinue) {
        Add-MCP -Name "MCP_DOCKER" -Args @("MCP_DOCKER", "--", "docker", "mcp", "gateway", "run")
    } else {
        Write-Host "  ! MCP_DOCKER (docker not found)"
    }

    # {{ if .azure_devops_org }}
    # Azure DevOps (org-scoped)
    Add-MCP -Name "azure-devops" -Args @("azure-devops", "--", "npx", "-y", "@azure-devops/mcp@2.5.0", "# {{ .azure_devops_org }}")
    # {{ end }}

    # {{ if and .enable_api_mcps (lookPath "bw") }}
    # Bitwarden-backed API MCPs
    Add-MCP -Name "exa" -Args @("exa", "--", "node", $bwMcp, "exa-api-key", "EXA_API_KEY=password", "--", "npx", "-y", "exa-mcp-server@3.1.9")
    Add-MCP -Name "firecrawl" -Args @("firecrawl", "--", "node", $bwMcp, "firecrawl-api-key", "FIRECRAWL_API_KEY=password", "--", "npx", "-y", "firecrawl-mcp@3.11.0")
    Add-MCP -Name "fal-ai" -Args @("fal-ai", "--", "node", $bwMcp, "fal-api-key", "FAL_KEY=password", "--", "npx", "-y", "fal-ai-mcp-server@2.1.4")
    # {{ end }}
} else {
    Write-Host "claude CLI not found - skipping Claude Code MCP setup"
}

# ============================================================
# 2. Claude Desktop App - merge mcpServers into existing config
# ============================================================

$claudeDesktopConfig = "$env:APPDATA\Claude\claude_desktop_config.json"

if (Test-Path $claudeDesktopConfig) {
    Write-Host ""
    Write-Host "Configuring Claude Desktop App MCPs..."

    try {
        $config = Get-Content $claudeDesktopConfig -Raw | ConvertFrom-Json
        $devDir = Join-Path $env:USERPROFILE "Dev"
        $bwMcp = Join-Path $env:USERPROFILE ".local\bin\bw-mcp"
        New-Item -ItemType Directory -Path $devDir -Force | Out-Null
        $mcpServers = @{
            playwright = @{ command = "npx"; args = @("-y", "@playwright/mcp@0.0.68") }
            context7 = @{ url = "https://mcp.context7.com/mcp" }
            figma = @{ url = "https://mcp.figma.com/mcp" }
            filesystem = @{ command = "npx"; args = @("-y", "@modelcontextprotocol/server-filesystem@2026.1.14", $devDir) }
            git = @{ command = "npx"; args = @("-y", "@cyanheads/git-mcp-server@2.10.5") }
            shell = @{ command = "npx"; args = @("-y", "super-shell-mcp@2.0.15") }
            terraform = @{ command = "npx"; args = @("-y", "terraform-mcp-server@0.13.0") }
            kubernetes = @{ command = "npx"; args = @("-y", "mcp-server-kubernetes@3.4.0") }
            process = @{ command = "npx"; args = @("-y", "@ai-capabilities-suite/mcp-process@1.5.10") }
            thinking = @{ command = "npx"; args = @("-y", "@modelcontextprotocol/server-sequential-thinking@2025.12.18") }
            memory = @{ command = "npx"; args = @("-y", "@modelcontextprotocol/server-memory@2026.1.26") }
        }
        if (Get-Command uvx -ErrorAction SilentlyContinue) {
            $mcpServers.http = @{ command = "uvx"; args = @("mcp-server-fetch==2025.4.7") }
        }
        if (Get-Command bw -ErrorAction SilentlyContinue) {
            $mcpServers.github = @{ command = "node"; args = @($bwMcp, "mcp-github", "GITHUB_PERSONAL_ACCESS_TOKEN=password", "--", "npx", "-y", "@modelcontextprotocol/server-github@2025.4.8") }
            $mcpServers.tailscale = @{ command = "node"; args = @($bwMcp, "mcp-tailscale", "TAILSCALE_API_KEY=password,TAILSCALE_TAILNET=TAILSCALE_TAILNET", "--", "npx", "-y", "@hexsleeves/tailscale-mcp-server@0.3.2") }
            if (Get-Command uvx -ErrorAction SilentlyContinue) {
                $mcpServers.aws = @{ command = "node"; args = @($bwMcp, "mcp-aws", "AWS_ACCESS_KEY_ID=AWS_ACCESS_KEY_ID,AWS_SECRET_ACCESS_KEY=AWS_SECRET_ACCESS_KEY", "--", "uvx", "awslabs.aws-api-mcp-server==1.3.26") }
            }
        }
        if (Get-Command docker -ErrorAction SilentlyContinue) {
            $mcpServers.MCP_DOCKER = @{ command = "docker"; args = @("mcp", "gateway", "run") }
        }
        # {{ if .azure_devops_org }}
        $mcpServers."azure-devops" = @{ command = "npx"; args = @("-y", "@azure-devops/mcp@2.5.0", "{{ .azure_devops_org }}") }
        # {{ end }}
        # {{ if and .enable_api_mcps (lookPath "bw") }}
        $mcpServers.exa = @{ command = "node"; args = @($bwMcp, "exa-api-key", "EXA_API_KEY=password", "--", "npx", "-y", "exa-mcp-server@3.1.9") }
        $mcpServers.firecrawl = @{ command = "node"; args = @($bwMcp, "firecrawl-api-key", "FIRECRAWL_API_KEY=password", "--", "npx", "-y", "firecrawl-mcp@3.11.0") }
        $mcpServers."fal-ai" = @{ command = "node"; args = @($bwMcp, "fal-api-key", "FAL_KEY=password", "--", "npx", "-y", "fal-ai-mcp-server@2.1.4") }
        # {{ end }}
        $config | Add-Member -NotePropertyName "mcpServers" -NotePropertyValue $mcpServers -Force
        $config | ConvertTo-Json -Depth 10 | Set-Content $claudeDesktopConfig
        Write-Host "  + Claude Desktop MCPs updated"
    } catch {
        Write-Host "  ! Failed to update Claude Desktop config: $_"
        $failed++
    }
} else {
    Write-Host ""
    Write-Host "Claude Desktop not found - skipping"
}

# ============================================================
# Summary
# ============================================================

Write-Host ""
if ($failed -eq 0) {
    Write-Host "All MCPs configured. OAuth servers will prompt in browser on first use."
} else {
    Write-Host "$failed item(s) failed. Re-run 'chezmoi apply' or configure manually."
}

exit 0
