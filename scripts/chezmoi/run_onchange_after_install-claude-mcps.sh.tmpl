#!/usr/bin/env bash
# chezmoi:template:left-delimiter="# {{" right-delimiter="}}"
# Registers MCP servers in Claude Code CLI and Claude Desktop App.
# Idempotent: removes then re-adds each server.
# Re-runs only when template output changes (chezmoi run_onchange_).
#
# hash: # {{ include "dot_cursor/mcp.json.tmpl" | sha256sum }}

set -uo pipefail

FAILED=0

# ============================================================
# 1. Claude Code CLI - via `claude mcp add`
# ============================================================

if command -v claude >/dev/null 2>&1; then
  echo "Configuring Claude Code CLI MCPs..."
  DEV_DIR="$HOME/Dev"
  BW_MCP="$HOME/.local/bin/bw-mcp"
  mkdir -p "$DEV_DIR"

  add_mcp() {
    local name="$1"; shift
    claude mcp remove --scope user "$name" 2>/dev/null || true
    if claude mcp add --scope user "$@" 2>/dev/null; then
      echo "  + $name"
    else
      echo "  ! $name (failed)"
      FAILED=$((FAILED + 1))
    fi
  }

  # Core MCPs (always installed)
  add_mcp playwright playwright -- npx -y @playwright/mcp@0.0.68
  add_mcp context7 --transport http context7 "https://mcp.context7.com/mcp"
  add_mcp figma --transport http figma "https://mcp.figma.com/mcp"
  add_mcp filesystem filesystem -- npx -y @modelcontextprotocol/server-filesystem@2026.1.14 "$DEV_DIR"
  add_mcp git git -- npx -y @cyanheads/git-mcp-server@2.10.5
  add_mcp shell shell -- npx -y super-shell-mcp@2.0.15
  add_mcp terraform terraform -- npx -y terraform-mcp-server@0.13.0
  add_mcp kubernetes kubernetes -- npx -y mcp-server-kubernetes@3.4.0
  add_mcp process process -- npx -y @ai-capabilities-suite/mcp-process@1.5.10
  add_mcp thinking thinking -- npx -y @modelcontextprotocol/server-sequential-thinking@2025.12.18
  add_mcp memory memory -- npx -y @modelcontextprotocol/server-memory@2026.1.26

  if command -v uvx >/dev/null 2>&1; then
    add_mcp http http -- uvx mcp-server-fetch==2025.4.7
  else
    echo "  ! http (uvx not found)"
  fi

  if command -v bw >/dev/null 2>&1; then
    add_mcp github github -- node "$BW_MCP" mcp-github GITHUB_PERSONAL_ACCESS_TOKEN=password -- npx -y @modelcontextprotocol/server-github@2025.4.8
    add_mcp tailscale tailscale -- node "$BW_MCP" mcp-tailscale TAILSCALE_API_KEY=password,TAILSCALE_TAILNET=TAILSCALE_TAILNET -- npx -y @hexsleeves/tailscale-mcp-server@0.3.2
    if command -v uvx >/dev/null 2>&1; then
      add_mcp aws aws -- node "$BW_MCP" mcp-aws AWS_ACCESS_KEY_ID=AWS_ACCESS_KEY_ID,AWS_SECRET_ACCESS_KEY=AWS_SECRET_ACCESS_KEY -- uvx awslabs.aws-api-mcp-server==1.3.26
    else
      echo "  ! aws (uvx not found)"
    fi
  else
    echo "  ! github (Bitwarden CLI not found)"
    echo "  ! aws (Bitwarden CLI not found)"
    echo "  ! tailscale (Bitwarden CLI not found)"
  fi

  if command -v docker >/dev/null 2>&1; then
    add_mcp MCP_DOCKER MCP_DOCKER -- docker mcp gateway run
  else
    echo "  ! MCP_DOCKER (docker not found)"
  fi

  # {{ if .azure_devops_org }}
  # Azure DevOps (org-scoped)
  add_mcp azure-devops azure-devops -- npx -y @azure-devops/mcp@2.5.0 # {{ .azure_devops_org }}
  # {{ end }}

  # {{ if and .enable_api_mcps (lookPath "bw") }}
  # Bitwarden-backed API MCPs
  add_mcp exa exa -- node "$BW_MCP" exa-api-key EXA_API_KEY=password -- npx -y exa-mcp-server@3.1.9
  add_mcp firecrawl firecrawl -- node "$BW_MCP" firecrawl-api-key FIRECRAWL_API_KEY=password -- npx -y firecrawl-mcp@3.11.0
  add_mcp fal-ai fal-ai -- node "$BW_MCP" fal-api-key FAL_KEY=password -- npx -y fal-ai-mcp-server@2.1.4
  # {{ end }}
else
  echo "claude CLI not found - skipping Claude Code MCP setup"
fi

# ============================================================
# 2. Claude Desktop App - merge mcpServers into existing config
# ============================================================

# Detect config path per platform
if [ "$(uname -s)" = "Darwin" ]; then
  CLAUDE_DESKTOP_CONFIG="$HOME/Library/Application Support/Claude/claude_desktop_config.json"
elif [ -n "${APPDATA:-}" ]; then
  CLAUDE_DESKTOP_CONFIG="$APPDATA/Claude/claude_desktop_config.json"
else
  CLAUDE_DESKTOP_CONFIG="$HOME/.config/Claude/claude_desktop_config.json"
fi

if [ -f "$CLAUDE_DESKTOP_CONFIG" ]; then
  echo ""
  echo "Configuring Claude Desktop App MCPs..."
  DEV_DIR="$HOME/Dev"
  BW_MCP="$HOME/.local/bin/bw-mcp"
  mkdir -p "$DEV_DIR"

  # Build the mcpServers JSON - same servers as Cursor config
  MCP_SERVERS=$(cat <<'MCPJSON'
{
  "playwright": {
    "command": "npx",
    "args": ["-y", "@playwright/mcp@0.0.68"]
  },
  "context7": {
    "url": "https://mcp.context7.com/mcp"
  },
  "figma": {
    "url": "https://mcp.figma.com/mcp"
  },
  "filesystem": {
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-filesystem@2026.1.14", "REPLACE_DEV_DIR"]
  },
  "git": {
    "command": "npx",
    "args": ["-y", "@cyanheads/git-mcp-server@2.10.5"]
  },
  "shell": {
    "command": "npx",
    "args": ["-y", "super-shell-mcp@2.0.15"]
  },
  "terraform": {
    "command": "npx",
    "args": ["-y", "terraform-mcp-server@0.13.0"]
  },
  "kubernetes": {
    "command": "npx",
    "args": ["-y", "mcp-server-kubernetes@3.4.0"]
  },
  "process": {
    "command": "npx",
    "args": ["-y", "@ai-capabilities-suite/mcp-process@1.5.10"]
  },
  "thinking": {
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-sequential-thinking@2025.12.18"]
  },
  "memory": {
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-memory@2026.1.26"]
  }
}
MCPJSON
)
  MCP_SERVERS="${MCP_SERVERS/REPLACE_DEV_DIR/$DEV_DIR}"
  if command -v python3 >/dev/null 2>&1; then
    if command -v uvx >/dev/null 2>&1; then
      MCP_SERVERS=$(python3 -c 'import json, sys; data=json.loads(sys.stdin.read()); data["http"]={"command":"uvx","args":["mcp-server-fetch==2025.4.7"]}; print(json.dumps(data))' <<<"$MCP_SERVERS")
    fi
    if command -v bw >/dev/null 2>&1; then
      MCP_SERVERS=$(python3 -c 'import json, sys; data=json.loads(sys.stdin.read()); bw=sys.argv[1]; data["github"]={"command":"node","args":[bw,"mcp-github","GITHUB_PERSONAL_ACCESS_TOKEN=password","--","npx","-y","@modelcontextprotocol/server-github@2025.4.8"]}; data["tailscale"]={"command":"node","args":[bw,"mcp-tailscale","TAILSCALE_API_KEY=password,TAILSCALE_TAILNET=TAILSCALE_TAILNET","--","npx","-y","@hexsleeves/tailscale-mcp-server@0.3.2"]}; print(json.dumps(data))' "$BW_MCP" <<<"$MCP_SERVERS")
      if command -v uvx >/dev/null 2>&1; then
        MCP_SERVERS=$(python3 -c 'import json, sys; data=json.loads(sys.stdin.read()); bw=sys.argv[1]; data["aws"]={"command":"node","args":[bw,"mcp-aws","AWS_ACCESS_KEY_ID=AWS_ACCESS_KEY_ID,AWS_SECRET_ACCESS_KEY=AWS_SECRET_ACCESS_KEY","--","uvx","awslabs.aws-api-mcp-server==1.3.26"]}; print(json.dumps(data))' "$BW_MCP" <<<"$MCP_SERVERS")
      fi
    fi
    if command -v docker >/dev/null 2>&1; then
      MCP_SERVERS=$(python3 -c 'import json, sys; data=json.loads(sys.stdin.read()); data["MCP_DOCKER"]={"command":"docker","args":["mcp","gateway","run"]}; print(json.dumps(data))' <<<"$MCP_SERVERS")
    fi
    # {{ if .azure_devops_org }}
    MCP_SERVERS=$(python3 -c 'import json, sys; data=json.loads(sys.stdin.read()); data["azure-devops"]={"command":"npx","args":["-y","@azure-devops/mcp@2.5.0","{{ .azure_devops_org }}"]}; print(json.dumps(data))' <<<"$MCP_SERVERS")
    # {{ end }}
    # {{ if and .enable_api_mcps (lookPath "bw") }}
    MCP_SERVERS=$(python3 -c 'import json, sys; data=json.loads(sys.stdin.read()); bw=sys.argv[1]; data["exa"]={"command":"node","args":[bw,"exa-api-key","EXA_API_KEY=password","--","npx","-y","exa-mcp-server@3.1.9"]}; data["firecrawl"]={"command":"node","args":[bw,"firecrawl-api-key","FIRECRAWL_API_KEY=password","--","npx","-y","firecrawl-mcp@3.11.0"]}; data["fal-ai"]={"command":"node","args":[bw,"fal-api-key","FAL_KEY=password","--","npx","-y","fal-ai-mcp-server@2.1.4"]}; print(json.dumps(data))' "$BW_MCP" <<<"$MCP_SERVERS")
    # {{ end }}
  fi

  # Merge into existing config using python3 (preserves all other keys)
  if command -v python3 >/dev/null 2>&1; then
    python3 -c "
import json, sys

config_path = sys.argv[1]
new_mcps = json.loads(sys.argv[2])

with open(config_path, 'r') as f:
    config = json.load(f)

config['mcpServers'] = new_mcps

with open(config_path, 'w') as f:
    json.dump(config, f, indent=2)
    f.write('\n')

print('  + Claude Desktop MCPs updated')
" "$CLAUDE_DESKTOP_CONFIG" "$MCP_SERVERS"
  else
    echo "  ! python3 not found - skipping Claude Desktop config"
    FAILED=$((FAILED + 1))
  fi
else
  echo ""
  echo "Claude Desktop not found - skipping"
fi

# ============================================================
# Summary
# ============================================================

echo ""
if [ "$FAILED" -eq 0 ]; then
  echo "All MCPs configured. OAuth servers will prompt in browser on first use."
else
  echo "$FAILED item(s) failed. Re-run 'chezmoi apply' or configure manually."
fi

exit 0
