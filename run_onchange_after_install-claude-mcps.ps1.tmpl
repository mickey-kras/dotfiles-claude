# chezmoi:template:left-delimiter="# {{" right-delimiter="}}"
# Installs MCP servers into Claude Code via `claude mcp add --scope user`.
# OAuth-based MCPs trigger browser auth on first use — no API keys needed.
# Re-runs whenever this template's rendered content changes.
#
# hash: # {{ include "dot_cursor/mcp.json.tmpl" | sha256sum }}

$ErrorActionPreference = "Stop"

if (-not (Get-Command claude -ErrorAction SilentlyContinue)) {
    Write-Host "claude CLI not found, skipping MCP setup"
    exit 0
}

Write-Host "Configuring Claude Code MCP servers..."

# Remove existing managed MCPs to avoid duplicates
foreach ($name in @("sequential-thinking", "playwright", "context7", "github")) {
    claude mcp remove --scope user $name 2>$null
}

# Sequential Thinking (local, no auth)
claude mcp add --scope user sequential-thinking -- npx -y @modelcontextprotocol/server-sequential-thinking
Write-Host "  + sequential-thinking"

# Playwright (local, no auth)
claude mcp add --scope user playwright -- npx -y "@playwright/mcp@latest"
Write-Host "  + playwright"

# Context7 (remote HTTP, OAuth)
claude mcp add --scope user --transport http --url "https://mcp.context7.com/mcp" context7
Write-Host "  + context7 (OAuth - will prompt in browser on first use)"

# GitHub (remote HTTP, OAuth)
claude mcp add --scope user --transport http --url "https://api.githubcopilot.com/mcp" github
Write-Host "  + github (OAuth - will prompt in browser on first use)"

Write-Host ""
Write-Host "Claude Code MCPs configured. OAuth servers will prompt to authorize in your browser on first use."
