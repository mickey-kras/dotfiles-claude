# chezmoi:template:left-delimiter="# {{" right-delimiter="}}"
# Registers MCP servers in Claude Code via `claude mcp add --scope user`.
# Idempotent: removes then re-adds each server independently.
# OAuth MCPs trigger browser auth on first use — no keys needed.
# Re-runs only when template output changes (chezmoi run_onchange_).
#
# hash: # {{ include "dot_cursor/mcp.json.tmpl" | sha256sum }}

$ErrorActionPreference = "Continue"

if (-not (Get-Command claude -ErrorAction SilentlyContinue)) {
    Write-Host "claude CLI not found, skipping MCP setup"
    exit 0
}

Write-Host "Configuring Claude Code MCP servers..."

$failed = 0

function Add-MCP {
    param([string]$Name, [string[]]$Args)
    claude mcp remove --scope user $Name 2>$null
    try {
        claude mcp add --scope user @Args 2>$null
        Write-Host "  + $Name"
    } catch {
        Write-Host "  ! $Name (failed)"
        $script:failed++
    }
}

# Local MCPs (stdio, no auth)
Add-MCP -Name "sequential-thinking" -Args @("sequential-thinking", "--", "npx", "-y", "@modelcontextprotocol/server-sequential-thinking")
Add-MCP -Name "playwright" -Args @("playwright", "--", "npx", "-y", "@playwright/mcp@latest")

# Remote MCPs (HTTP, OAuth)
Add-MCP -Name "context7" -Args @("--transport", "http", "context7", "https://mcp.context7.com/mcp")
Add-MCP -Name "github" -Args @("--transport", "http", "github", "https://api.githubcopilot.com/mcp")

Write-Host ""
if ($failed -eq 0) {
    Write-Host "All MCPs configured. OAuth servers will prompt in browser on first use."
} else {
    Write-Host "$failed MCP(s) failed to register."
}

exit 0
