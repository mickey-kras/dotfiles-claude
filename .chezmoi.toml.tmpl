{{- /* Chezmoi config — runs during `chezmoi init`. Re-run init to change values. */ -}}

{{- $email := promptStringOnce . "email" "Email address" -}}
{{- $machine := promptStringOnce . "machine" "Name for this machine (e.g. personal-mac, work-laptop)" -}}

[data]
  email = {{ $email | quote }}
  machine = {{ $machine | quote }}
