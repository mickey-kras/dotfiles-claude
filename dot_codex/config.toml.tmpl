# Codex global configuration
# Managed by chezmoi — edit the template at ~/dotfiles-claude/dot_codex/config.toml.tmpl

model = "gpt-5.4"
model_reasoning_effort = "medium"

# Global instructions for all Codex sessions
instructions = """
Follow TDD: write a failing test first, then implement, then refactor.
Apply SOLID principles and DRY. Use design patterns where they reduce coupling.
Conventional Commits for git messages. Never commit to main directly.
"""

[mcp_servers.sequential-thinking]
command = "npx"
args = ["-y", "@modelcontextprotocol/server-sequential-thinking"]

[mcp_servers.playwright]
command = "npx"
args = ["-y", "@playwright/mcp@latest"]

[mcp_servers.context7]
type = "http"
url = "https://mcp.context7.com/mcp"

[mcp_servers.github]
type = "http"
url = "https://api.githubcopilot.com/mcp"

[mcp_servers.cloudflare-docs]
type = "http"
url = "https://docs.mcp.cloudflare.com/mcp"

[mcp_servers.vercel]
type = "http"
url = "https://mcp.vercel.com"

[mcp_servers.magic-ui]
command = "npx"
args = ["-y", "@magicuidesign/mcp@latest"]
{{ if .enable_api_mcps }}
[mcp_servers.exa]
command = "npx"
args = ["-y", "exa-mcp-server"]
[mcp_servers.exa.env]
EXA_API_KEY = "{{ (bitwarden "item" "exa-api-key").login.password }}"

[mcp_servers.firecrawl]
command = "npx"
args = ["-y", "firecrawl-mcp"]
[mcp_servers.firecrawl.env]
FIRECRAWL_API_KEY = "{{ (bitwarden "item" "firecrawl-api-key").login.password }}"

[mcp_servers.fal-ai]
command = "npx"
args = ["-y", "fal-ai-mcp-server"]
[mcp_servers.fal-ai.env]
FAL_KEY = "{{ (bitwarden "item" "fal-api-key").login.password }}"
{{ end }}
