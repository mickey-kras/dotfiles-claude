# Codex global configuration
# Managed by chezmoi — edit the template at ~/dotfiles-claude/dot_codex/config.toml.tmpl

model = "o4-mini"

# Global instructions for all Codex sessions
instructions = """
Follow TDD: write a failing test first, then implement, then refactor.
Apply SOLID principles and DRY. Use design patterns where they reduce coupling.
Conventional Commits for git messages. Never commit to main directly.
"""

[mcp_servers.sequential-thinking]
command = "npx"
args = ["-y", "@modelcontextprotocol/server-sequential-thinking"]

[mcp_servers.playwright]
command = "npx"
args = ["-y", "@playwright/mcp@latest"]

[mcp_servers.context7]
type = "http"
url = "https://mcp.context7.com/mcp"

[mcp_servers.github]
type = "http"
url = "https://api.githubcopilot.com/mcp"
