{{- $home := replace "\\" "/" .chezmoi.homeDir -}}
{{- $runtime := includeTemplate "templates/resolved-state.json" . | fromJson -}}
{{- $resolved := $runtime.resolved -}}
{{- $selectedMcps := index $resolved "mcps" "enabled" -}}
{{- $settings := index $resolved "settings" -}}
# Runtime profile: {{ index $runtime "state" "profile" "requested" }}
# Capability pack: {{ index $resolved "pack_id" }}
# Codex global configuration
# Managed by chezmoi - edit the template at ~/dotfiles/dot_codex/config.toml.tmpl

model = "gpt-5.4"
model_reasoning_effort = "medium"

{{ if has "playwright" $selectedMcps }}
[mcp_servers.playwright]
command = "npx"
args = ["-y", "@playwright/mcp@0.0.68"]
{{ end }}

{{ if has "slack" $selectedMcps }}
[mcp_servers.slack]
type = "http"
url = "https://mcp.slack.com/mcp"

[mcp_servers.slack.oauth]
clientId = "1601185624273.8899143856786"
callbackPort = 3118
{{ end }}

{{ if has "atlassian" $selectedMcps }}
[mcp_servers.atlassian]
type = "http"
url = "https://mcp.atlassian.com/v1/mcp"
{{ end }}

{{ if has "context7" $selectedMcps }}
[mcp_servers.context7]
type = "http"
url = "https://mcp.context7.com/mcp"
{{ end }}

{{ if has "filesystem" $selectedMcps }}
[mcp_servers.filesystem]
command = "npx"
args = ["-y", "@modelcontextprotocol/server-filesystem@2026.1.14", "{{ $home }}/Dev"]
{{ end }}

{{ if has "git" $selectedMcps }}
[mcp_servers.git]
command = "npx"
args = ["-y", "@cyanheads/git-mcp-server@2.10.5"]
{{ end }}

{{ if has "shell" $selectedMcps }}
[mcp_servers.shell]
command = "npx"
args = ["-y", "super-shell-mcp@2.0.15"]
{{ end }}

{{ if has "terraform" $selectedMcps }}
[mcp_servers.terraform]
command = "npx"
args = ["-y", "terraform-mcp-server@0.13.0"]
{{ end }}

{{ if has "kubernetes" $selectedMcps }}
[mcp_servers.kubernetes]
command = "npx"
args = ["-y", "mcp-server-kubernetes@3.4.0"]
{{ end }}

{{ if has "process" $selectedMcps }}
[mcp_servers.process]
command = "npx"
args = ["-y", "@ai-capabilities-suite/mcp-process@1.5.10"]
{{ end }}

{{ if has "thinking" $selectedMcps }}
[mcp_servers.thinking]
command = "npx"
args = ["-y", "@modelcontextprotocol/server-sequential-thinking@2025.12.18"]
{{ end }}

{{ if has "memory" $selectedMcps }}
[mcp_servers.memory]
{{ if and (eq (index $settings "memory_provider") "obsidian") (index $settings "obsidian_vault_path") }}
command = "npx"
args = ["-y", "@bitbonsai/mcpvault@latest", {{ index $settings "obsidian_vault_path" | toJson }}]
{{ else }}
command = "npx"
args = ["-y", "@modelcontextprotocol/server-memory@2026.1.26"]
{{ end }}
{{ end }}

{{ if and (has "http" $selectedMcps) (lookPath "uvx") }}
[mcp_servers.http]
command = "uvx"
args = ["mcp-server-fetch==2025.4.7"]
{{ end }}

{{ if has "figma" $selectedMcps }}
[mcp_servers.figma]
type = "http"
url = "https://mcp.figma.com/mcp"
{{ end }}

{{ if and (has "azure-devops" $selectedMcps) (index $settings "azure_devops_org") }}
[mcp_servers.azure-devops]
command = "npx"
args = ["-y", "@azure-devops/mcp@2.5.0", "{{ index $settings "azure_devops_org" }}"]
{{ end }}
{{ if and (has "github" $selectedMcps) (lookPath "bw") }}
[mcp_servers.github]
command = "node"
args = ["{{ $home }}/.local/bin/bw-mcp", "mcp-github", "GITHUB_PERSONAL_ACCESS_TOKEN=password", "--", "npx", "-y", "@modelcontextprotocol/server-github@2025.4.8"]
{{ end }}

{{ if and (has "tailscale" $selectedMcps) (lookPath "bw") }}
[mcp_servers.tailscale]
command = "node"
args = ["{{ $home }}/.local/bin/bw-mcp", "mcp-tailscale", "TAILSCALE_API_KEY=password,TAILSCALE_TAILNET=TAILSCALE_TAILNET", "--", "npx", "-y", "@hexsleeves/tailscale-mcp-server@0.3.2"]
{{ end }}

{{ if and (has "aws" $selectedMcps) (lookPath "bw") (lookPath "uvx") }}
[mcp_servers.aws]
command = "node"
args = ["{{ $home }}/.local/bin/bw-mcp", "mcp-aws", "AWS_ACCESS_KEY_ID=AWS_ACCESS_KEY_ID,AWS_SECRET_ACCESS_KEY=AWS_SECRET_ACCESS_KEY", "--", "uvx", "awslabs.aws-api-mcp-server==1.3.26"]
{{ end }}

{{ if and (has "exa" $selectedMcps) (lookPath "bw") }}
[mcp_servers.exa]
command = "node"
args = ["{{ $home }}/.local/bin/bw-mcp", "exa-api-key", "EXA_API_KEY=password", "--", "npx", "-y", "exa-mcp-server@3.1.9"]
{{ end }}

{{ if and (has "firecrawl" $selectedMcps) (lookPath "bw") }}
[mcp_servers.firecrawl]
command = "node"
args = ["{{ $home }}/.local/bin/bw-mcp", "firecrawl-api-key", "FIRECRAWL_API_KEY=password", "--", "npx", "-y", "firecrawl-mcp@3.11.0"]
{{ end }}

{{ if and (has "fal-ai" $selectedMcps) (lookPath "bw") }}
[mcp_servers.fal-ai]
command = "node"
args = ["{{ $home }}/.local/bin/bw-mcp", "fal-api-key", "FAL_KEY=password", "--", "npx", "-y", "fal-ai-mcp-server@2.1.4"]
{{ end }}

{{ if and (has "docker" $selectedMcps) (lookPath "docker") }}
[mcp_servers.MCP_DOCKER]
command = "docker"
args = ["mcp", "gateway", "run"]
{{ end }}
