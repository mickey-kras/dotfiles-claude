{{- $home := replace "\\" "/" .chezmoi.homeDir -}}
# Codex global configuration
# Managed by chezmoi - edit the template at ~/dotfiles/dot_codex/config.toml.tmpl

model = "gpt-5.4"
model_reasoning_effort = "medium"

[mcp_servers.playwright]
command = "npx"
args = ["-y", "@playwright/mcp@0.0.68"]

[mcp_servers.slack]
type = "http"
url = "https://mcp.slack.com/mcp"

[mcp_servers.slack.oauth]
clientId = "1601185624273.8899143856786"
callbackPort = 3118

[mcp_servers.atlassian]
command = "npx"
args = ["-y", "@atlassian/mcp"]

[mcp_servers.context7]
type = "http"
url = "https://mcp.context7.com/mcp"

[mcp_servers.filesystem]
command = "npx"
args = ["-y", "@modelcontextprotocol/server-filesystem@2026.1.14", "{{ $home }}/Dev"]

[mcp_servers.git]
command = "npx"
args = ["-y", "@cyanheads/git-mcp-server@2.10.5"]

[mcp_servers.shell]
command = "npx"
args = ["-y", "super-shell-mcp@2.0.15"]

[mcp_servers.terraform]
command = "npx"
args = ["-y", "terraform-mcp-server@0.13.0"]

[mcp_servers.kubernetes]
command = "npx"
args = ["-y", "mcp-server-kubernetes@3.4.0"]

[mcp_servers.process]
command = "npx"
args = ["-y", "@ai-capabilities-suite/mcp-process@1.5.10"]

[mcp_servers.thinking]
command = "npx"
args = ["-y", "@modelcontextprotocol/server-sequential-thinking@2025.12.18"]

[mcp_servers.memory]
command = "npx"
args = ["-y", "@modelcontextprotocol/server-memory@2026.1.26"]

{{ if lookPath "uvx" }}
[mcp_servers.http]
command = "uvx"
args = ["mcp-server-fetch==2025.4.7"]
{{ end }}

[mcp_servers.figma]
type = "http"
url = "https://mcp.figma.com/mcp"

[plugins."github@openai-curated"]
enabled = true

[plugins."claude-import@misha-local"]
enabled = true
{{ if .azure_devops_org }}
[mcp_servers.azure-devops]
command = "npx"
args = ["-y", "@azure-devops/mcp@2.5.0", "{{ .azure_devops_org }}"]
{{ end }}
{{ if and .enable_api_mcps (lookPath "bw") }}
[mcp_servers.github]
command = "node"
args = ["{{ $home }}/.local/bin/bw-mcp", "mcp-github", "GITHUB_PERSONAL_ACCESS_TOKEN=password", "--", "npx", "-y", "@modelcontextprotocol/server-github@2025.4.8"]

[mcp_servers.tailscale]
command = "node"
args = ["{{ $home }}/.local/bin/bw-mcp", "mcp-tailscale", "TAILSCALE_API_KEY=password,TAILSCALE_TAILNET=TAILSCALE_TAILNET", "--", "npx", "-y", "@hexsleeves/tailscale-mcp-server@0.3.2"]

{{ if lookPath "uvx" }}
[mcp_servers.aws]
command = "node"
args = ["{{ $home }}/.local/bin/bw-mcp", "mcp-aws", "AWS_ACCESS_KEY_ID=AWS_ACCESS_KEY_ID,AWS_SECRET_ACCESS_KEY=AWS_SECRET_ACCESS_KEY", "--", "uvx", "awslabs.aws-api-mcp-server==1.3.26"]
{{ end }}

[mcp_servers.exa]
command = "node"
args = ["{{ $home }}/.local/bin/bw-mcp", "exa-api-key", "EXA_API_KEY=password", "--", "npx", "-y", "exa-mcp-server@3.1.9"]

[mcp_servers.firecrawl]
command = "node"
args = ["{{ $home }}/.local/bin/bw-mcp", "firecrawl-api-key", "FIRECRAWL_API_KEY=password", "--", "npx", "-y", "firecrawl-mcp@3.11.0"]

[mcp_servers.fal-ai]
command = "node"
args = ["{{ $home }}/.local/bin/bw-mcp", "fal-api-key", "FAL_KEY=password", "--", "npx", "-y", "fal-ai-mcp-server@2.1.4"]
{{ end }}

{{ if lookPath "docker" }}
[mcp_servers.MCP_DOCKER]
command = "docker"
args = ["mcp", "gateway", "run"]
{{ end }}
