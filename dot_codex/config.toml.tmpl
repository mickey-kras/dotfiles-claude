# Codex global configuration
# Managed by chezmoi - edit the template at ~/dotfiles-claude/dot_codex/config.toml.tmpl

model = "gpt-5.4"
model_reasoning_effort = "medium"

[mcp_servers.playwright]
command = "npx"
args = ["-y", "@playwright/mcp@0.0.68"]

[mcp_servers.github]
type = "http"
url = "https://api.githubcopilot.com/mcp/"

[mcp_servers.github.headers]
Authorization = "Bearer ${GITHUB_PERSONAL_ACCESS_TOKEN}"

[mcp_servers.slack]
type = "http"
url = "https://mcp.slack.com/mcp"

[mcp_servers.slack.oauth]
clientId = "1601185624273.8899143856786"
callbackPort = 3118

[mcp_servers.atlassian]
command = "npx"
args = ["-y", "@atlassian/mcp"]

[mcp_servers.context7]
type = "http"
url = "https://mcp.context7.com/mcp"

[mcp_servers.sentry]
type = "http"
url = "https://mcp.sentry.dev/mcp"

[mcp_servers.figma]
type = "http"
url = "https://mcp.figma.com/mcp"

[plugins."github@openai-curated"]
enabled = true

[plugins."claude-import@misha-local"]
enabled = true
{{ if .azure_devops_org }}
[mcp_servers.azure-devops]
command = "npx"
args = ["-y", "@azure-devops/mcp@2.5.0", "{{ .azure_devops_org }}"]
{{ end }}
{{ if and .enable_api_mcps (lookPath "bw") }}
[mcp_servers.exa]
command = "npx"
args = ["-y", "exa-mcp-server@3.1.9"]
[mcp_servers.exa.env]
EXA_API_KEY = "{{ (bitwarden "item" "exa-api-key").login.password }}"

[mcp_servers.firecrawl]
command = "npx"
args = ["-y", "firecrawl-mcp@3.11.0"]
[mcp_servers.firecrawl.env]
FIRECRAWL_API_KEY = "{{ (bitwarden "item" "firecrawl-api-key").login.password }}"

[mcp_servers.fal-ai]
command = "npx"
args = ["-y", "fal-ai-mcp-server@2.1.4"]
[mcp_servers.fal-ai.env]
FAL_KEY = "{{ (bitwarden "item" "fal-api-key").login.password }}"
{{ end }}
