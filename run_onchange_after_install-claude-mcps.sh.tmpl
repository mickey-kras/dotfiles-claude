#!/usr/bin/env bash
# chezmoi:template:left-delimiter="# {{" right-delimiter="}}"
# Installs MCP servers into Claude Code via `claude mcp add --scope user`.
# OAuth-based MCPs trigger browser auth on first use — no API keys needed.
# Re-runs whenever this template's rendered content changes.
#
# hash: # {{ include "dot_cursor/mcp.json.tmpl" | sha256sum }}

set -euo pipefail

command -v claude >/dev/null 2>&1 || { echo "claude CLI not found, skipping MCP setup"; exit 0; }

echo "Configuring Claude Code MCP servers..."

# Remove existing managed MCPs to avoid duplicates, then re-add
for name in sequential-thinking playwright context7 github; do
  claude mcp remove --scope user "$name" 2>/dev/null || true
done

# Sequential Thinking (official MCP, local, no auth)
claude mcp add --scope user sequential-thinking -- npx -y @modelcontextprotocol/server-sequential-thinking
echo "  + sequential-thinking"

# Playwright (local, no auth)
claude mcp add --scope user playwright -- npx -y @playwright/mcp@latest
echo "  + playwright"

# Context7 (remote HTTP, OAuth — browser auth on first use)
claude mcp add --scope user --transport http --url "https://mcp.context7.com/mcp" context7
echo "  + context7 (OAuth — will prompt in browser on first use)"

# GitHub (remote HTTP, OAuth — browser auth on first use)
claude mcp add --scope user --transport http --url "https://api.githubcopilot.com/mcp" github
echo "  + github (OAuth — will prompt in browser on first use)"

echo ""
echo "Claude Code MCPs configured. OAuth servers will prompt to authorize in your browser on first use."
