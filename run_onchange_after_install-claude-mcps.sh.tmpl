#!/usr/bin/env bash
# chezmoi:template:left-delimiter="# {{" right-delimiter="}}"
# Registers MCP servers in Claude Code via `claude mcp add --scope user`.
# Idempotent: removes then re-adds each server independently.
# OAuth MCPs trigger browser auth on first use — no keys needed.
# Re-runs only when template output changes (chezmoi run_onchange_).
#
# hash: # {{ include "dot_cursor/mcp.json.tmpl" | sha256sum }}

set -uo pipefail

command -v claude >/dev/null 2>&1 || { echo "claude CLI not found, skipping MCP setup"; exit 0; }

echo "Configuring Claude Code MCP servers..."

FAILED=0

add_mcp() {
  local name="$1"; shift
  claude mcp remove --scope user "$name" 2>/dev/null || true
  if claude mcp add --scope user "$@" 2>/dev/null; then
    echo "  + $name"
  else
    echo "  ! $name (failed — run 'claude mcp add --scope user $*' manually)"
    FAILED=$((FAILED + 1))
  fi
}

# Local MCPs (stdio, no auth)
add_mcp sequential-thinking sequential-thinking -- npx -y @modelcontextprotocol/server-sequential-thinking
add_mcp playwright playwright -- npx -y @playwright/mcp@latest

# Remote MCPs (HTTP, OAuth — browser auth on first use)
add_mcp context7 --transport http context7 "https://mcp.context7.com/mcp"
add_mcp github --transport http github "https://api.githubcopilot.com/mcp"

echo ""
if [ "$FAILED" -eq 0 ]; then
  echo "All MCPs configured. OAuth servers will prompt in browser on first use."
else
  echo "$FAILED MCP(s) failed to register. See above for manual commands."
fi

exit 0
