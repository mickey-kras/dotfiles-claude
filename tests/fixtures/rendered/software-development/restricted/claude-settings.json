{
  "permissions": {
    "allow": [
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(gh pr checks*)",
      "Bash(gh pr view*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git status*)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(jq *)",
      "Bash(ls *)",
      "Bash(rg *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Edit",
      "Read",
      "Write"
    ],
    "deny": [
      "Bash(\u003e /dev/sda*)",
      "Bash(chmod 777 *)",
      "Bash(choco install*)",
      "Bash(dd if=/dev/zero*)",
      "Bash(npm i*)",
      "Bash(npm install*)",
      "Bash(npx *)",
      "Bash(pip install*)",
      "Bash(rm -rf /)",
      "Bash(su *)",
      "Bash(sudo *)",
      "Bash(uv *)",
      "Bash(uvx *)",
      "Bash(winget install*)"
    ]
  },
  "PreToolUse": [
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": "node $HOME/.claude/hooks/scripts/block-no-verify.js"
        },
        {
          "type": "command",
          "command": "node $HOME/.claude/hooks/scripts/governance-capture.js"
        }
      ]
    },
    {
      "matcher": "Write|Edit",
      "hooks": [
        {
          "type": "command",
          "command": "node $HOME/.claude/hooks/scripts/config-protection.js"
        }
      ]
    },
    {
      "matcher": "Write|Edit|MultiEdit",
      "hooks": [
        {
          "type": "command",
          "command": "python3 $HOME/.claude/hooks/scripts/security-review.py"
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "node $HOME/.claude/hooks/scripts/quality-gate.js"
        },
        {
          "type": "command",
          "command": "node $HOME/.claude/hooks/scripts/post-edit-format.js"
        },
        {
          "type": "command",
          "command": "node $HOME/.claude/hooks/scripts/suggest-compact.js"
        }
      ]
    }
  ],
  "env": {
    "EDITOR": "code --wait",
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false",
    "DOTFILES_RUNTIME_PROFILE": "restricted"
  },
  "model": "opus"
}
